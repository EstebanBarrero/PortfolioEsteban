---
import { PATHS } from '../../shared/icons';
interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 16, class: cls } = Astro.props;
const path = PATHS[name] ?? '';
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  width={size}
  height={size}
  class={cls}
  aria-hidden="true"
  set:html={path}
/>
